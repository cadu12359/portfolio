@inject LanguageService Lang

<div class="timeline-item experience-card">
    <div class="card-header">
        <h3 class="role">@Experience.Role</h3>
        <span class="date">
            @Experience.StartDate.ToString("MMM yyyy") -
            @(Experience.IsCurrent ? (Lang.Current == "pt" ? "Presente" : "Present") : Experience.EndDate?.ToString("MMM yyyy"))
        </span>
    </div>

    <h4 class="company">@Experience.Company</h4>

    <ul class="description-list">
        @foreach (var line in Experience.Description.Split('\n', StringSplitOptions.RemoveEmptyEntries))
        {
            <li>@line.Trim()</li>
        }
    </ul>

    <div class="tech-stack">
        @foreach (var tech in Experience.Technologies)
        {
            <span class="tech-tag">@tech</span>
        }
    </div>
</div>

@code {
    [Parameter] public required ExperienceDto Experience { get; set; }
}
